{
  "name": "prosale-pos-mongodb",
  "version": "1.0.0",
  "private": true,
  "description": "ProSale POS frontend linked to a Node.js API and MongoDB database.",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "python -m http.server 4173 --bind 127.0.0.1",
    "dev:backend": "npm --prefix backend run dev",
    "start": "npm --prefix backend start",
    "install:all": "npm install && npm --prefix backend install"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

